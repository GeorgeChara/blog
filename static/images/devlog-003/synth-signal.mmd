flowchart LR
    OSC["🎵 Oscillator\nSaw / Square / Sine"]
    SUB["Sub Osc\n-1 octave"]
    NOISE["Noise"]
    MIX["Mix"]
    FILT["Filter\nLP / HP / BP\nDiode Ladder"]
    DIST["Distortion"]
    AMP["Amp\nEnvelope"]
    DLY["Delay"]
    REV["Reverb"]
    OUT["🔊 Output"]

    OSC --> MIX
    SUB --> MIX
    NOISE --> MIX
    MIX --> FILT
    FILT --> DIST
    DIST --> AMP
    AMP --> DLY
